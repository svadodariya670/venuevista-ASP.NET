@model VenueBooking.ViewModels.OwnerMessagesViewModel
@{
    ViewData["Title"] = "Messages";
    Layout = "_OwnerLayout";
}

<div class="flex flex-col md:flex-row h-[calc(100vh-140px)] bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
    <!-- Left: Conversation List -->
    <aside class="w-full md:w-80 lg:w-96 border-b md:border-b-0 md:border-r border-slate-100 flex flex-col @(Model.SelectedCustomerId.HasValue ? "hidden md:flex" : "flex")">
        <div class="p-4 sm:p-6 border-b border-slate-100">
            <h1 class="text-xl font-bold text-text-main mb-4">Messages</h1>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm">search</span>
                <input type="text" id="searchConversations" placeholder="Search customers..."
                       class="w-full pl-10 pr-4 py-2 bg-background-light border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/20 placeholder:text-slate-400" />
            </div>
        </div>
        <div class="flex-1 overflow-y-auto" id="conversationsList">
            @if (!Model.Conversations.Any())
            {
                <div class="p-8 text-center">
                    <span class="material-symbols-outlined text-4xl text-slate-300 mb-2">chat</span>
                    <p class="text-sm text-slate-500">No messages yet</p>
                </div>
            }
            @foreach (var conv in Model.Conversations)
            {
                var isActive = Model.SelectedCustomerId == conv.CustomerId;
                <a asp-action="Conversation" asp-route-customerId="@conv.CustomerId"
                   class="block p-4 border-b border-slate-50 hover:bg-background-light transition-colors @(isActive ? "bg-primary/5 border-l-4 border-l-primary" : "border-l-4 border-l-transparent")">
                    <div class="flex gap-3">
                        <div class="relative flex-shrink-0">
                            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                                <span class="material-symbols-outlined text-xl sm:text-2xl">person</span>
                            </div>
                            @if (conv.UnreadCount > 0)
                            {
                                <div class="absolute -top-1 -right-1 w-5 h-5 bg-primary text-white text-xs font-bold rounded-full flex items-center justify-center">
                                    @conv.UnreadCount
                                </div>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="text-sm font-bold text-text-main truncate">@conv.CustomerName</h3>
                                <span class="text-[10px] text-slate-500 shrink-0 ml-2">@conv.LastMessageTime.ToString("MMM dd")</span>
                            </div>
                            <p class="text-xs font-semibold text-secondary mb-0.5 truncate">@conv.VenueName</p>
                            <p class="text-xs text-slate-600 truncate @(conv.UnreadCount > 0 ? "font-semibold" : "")">@conv.LastMessage</p>
                        </div>
                    </div>
                </a>
            }
        </div>
    </aside>

    <!-- Right: Chat Window -->
    <main class="flex-1 flex flex-col bg-background-light @(Model.SelectedCustomerId.HasValue ? "flex" : "hidden md:flex")">
        @if (Model.SelectedConversation != null)
        {
            <!-- Chat Header -->
            <header class="h-16 bg-white border-b border-slate-100 flex items-center justify-between px-4 sm:px-6 shrink-0">
                <div class="flex items-center gap-3">
                    <a asp-action="Messages" class="md:hidden p-1 text-slate-400 hover:text-slate-600">
                        <span class="material-symbols-outlined">arrow_back</span>
                    </a>
                    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                        <span class="material-symbols-outlined text-xl">person</span>
                    </div>
                    <div class="min-w-0">
                        <h2 class="font-bold text-sm text-text-main truncate">@Model.SelectedConversation.CustomerName</h2>
                        @if (Model.SelectedConversation.HasBooking)
                        {
                            <p class="text-xs text-secondary truncate">@Model.SelectedConversation.VenueName · @Model.SelectedConversation.EventType</p>
                        }
                    </div>
                </div>
                @if (Model.SelectedConversation.HasBooking && Model.SelectedConversation.BookingId.HasValue)
                {
                    <a asp-controller="Owner" asp-action="BookingDetails" asp-route-id="@Model.SelectedConversation.BookingId"
                       class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-primary hover:bg-primary/5 rounded-lg transition-colors border border-primary/20">
                        <span class="material-symbols-outlined text-sm">visibility</span>
                        View Booking
                    </a>
                }
            </header>

            <!-- Messages Area -->
            <div class="flex-1 overflow-y-auto p-4 sm:p-6 space-y-4" id="messagesContainer">
                @foreach (var message in Model.SelectedConversation.Messages)
                {
                    if (message.IsFromCurrentUser)
                    {
                        <div class="flex gap-3 max-w-[85%] sm:max-w-lg ml-auto flex-row-reverse">
                            <div class="w-7 h-7 rounded-full bg-primary flex items-center justify-center text-white flex-shrink-0 self-end">
                                <span class="material-symbols-outlined text-sm">person</span>
                            </div>
                            <div>
                                <div class="bg-primary p-3 rounded-xl rounded-tr-none text-white shadow-sm">
                                    <p class="text-sm leading-relaxed">@message.Content</p>
                                </div>
                                <p class="text-[10px] text-slate-400 text-right mt-1">@message.SentAt.ToString("h:mm tt")</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex gap-3 max-w-[85%] sm:max-w-lg">
                            <div class="w-7 h-7 rounded-full bg-secondary/10 flex items-center justify-center text-secondary flex-shrink-0 self-end">
                                <span class="material-symbols-outlined text-sm">person</span>
                            </div>
                            <div>
                                <div class="bg-white p-3 rounded-xl rounded-tl-none border border-slate-200 shadow-sm">
                                    <p class="text-sm leading-relaxed text-text-main">@message.Content</p>
                                </div>
                                <p class="text-[10px] text-slate-400 mt-1">@message.SentAt.ToString("h:mm tt")</p>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Send Error Banner -->
            <div id="sendError" class="hidden px-4 py-2 bg-red-50 border-t border-red-200 text-red-600 text-xs flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">error</span>
                <span id="sendErrorText">Failed to send message.</span>
            </div>

            <!-- Message Input -->
            <div class="p-3 sm:p-4 bg-white border-t border-slate-100 shrink-0">
                <form id="messageForm" class="flex items-end gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="receiverId" value="@Model.SelectedConversation.CustomerId" />
                    <div class="flex-1">
                        <textarea id="messageInput" rows="1"
                                  class="w-full bg-background-light border border-primary/10 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 resize-none"
                                  placeholder="Write your message..."
                                  oninput="this.style.height=''; this.style.height=Math.min(this.scrollHeight,120)+'px'"></textarea>
                    </div>
                    <button type="submit" id="ownerSendBtn" class="bg-primary text-white px-4 py-3 rounded-xl hover:bg-primary/90 transition-all flex items-center gap-1 shrink-0">
                        <span class="material-symbols-outlined text-lg">send</span>
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="flex-1 flex flex-col items-center justify-center text-slate-400 p-6">
                <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">forum</span>
                <p class="text-lg font-medium">Select a conversation</p>
                <p class="text-sm mt-1">Choose a customer from the list to view messages</p>
            </div>
        }
    </main>
</div>

@section Scripts {
    <script>
        // Search Filter
        document.getElementById('searchConversations')?.addEventListener('input', function () {
            const term = this.value.toLowerCase();
            document.querySelectorAll('#conversationsList > a').forEach(function (el) {
                const name = el.querySelector('h3')?.textContent.toLowerCase() || '';
                el.style.display = name.includes(term) ? 'block' : 'none';
            });
        });

        // Auto-scroll
        const mc = document.getElementById('messagesContainer');
        if (mc) mc.scrollTop = mc.scrollHeight;

        function showSendError(msg) {
            var el = document.getElementById('sendError');
            document.getElementById('sendErrorText').textContent = msg;
            el.classList.remove('hidden');
            setTimeout(function () { el.classList.add('hidden'); }, 5000);
        }

        // Send message via AJAX
        document.getElementById('messageForm')?.addEventListener('submit', function (e) {
            e.preventDefault();
            var content = document.getElementById('messageInput').value.trim();
            var receiverId = parseInt(document.getElementById('receiverId').value);
            var token = document.querySelector('#messageForm input[name="__RequestVerificationToken"]')?.value;
            var btn = document.getElementById('ownerSendBtn');

            if (!content) return;

            if (!token) {
                showSendError('Security token not found. Please refresh the page.');
                return;
            }

            // Hide previous error
            document.getElementById('sendError').classList.add('hidden');
            btn.disabled = true;

            fetch('@Url.Action("Send", "Owner")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ receiverId: receiverId, content: content })
            })
            .then(function (r) {
                if (!r.ok) throw new Error('Server returned ' + r.status);
                return r.json();
            })
            .then(function (data) {
                btn.disabled = false;
                if (data.success) {
                    var container = document.getElementById('messagesContainer');
                    container.insertAdjacentHTML('beforeend',
                        '<div class="flex gap-3 max-w-[85%] sm:max-w-lg ml-auto flex-row-reverse">' +
                            '<div class="w-7 h-7 rounded-full bg-primary flex items-center justify-center text-white flex-shrink-0 self-end">' +
                                '<span class="material-symbols-outlined text-sm">person</span>' +
                            '</div>' +
                            '<div>' +
                                '<div class="bg-primary p-3 rounded-xl rounded-tr-none text-white shadow-sm">' +
                                    '<p class="text-sm leading-relaxed">' + data.message.content + '</p>' +
                                '</div>' +
                                '<p class="text-[10px] text-slate-400 text-right mt-1">Just now</p>' +
                            '</div>' +
                        '</div>');
                    container.scrollTop = container.scrollHeight;
                    document.getElementById('messageInput').value = '';
                    document.getElementById('messageInput').style.height = 'auto';
                } else {
                    showSendError(data.error || 'Failed to send message.');
                }
            })
            .catch(function (err) {
                btn.disabled = false;
                console.error('Send error:', err);
                showSendError('Failed to send message. Please try again.');
            });
        });

        // Enter to send
        document.getElementById('messageInput')?.addEventListener('keypress', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                document.getElementById('messageForm').dispatchEvent(new Event('submit'));
            }
        });
    </script>
}