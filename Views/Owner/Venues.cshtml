@model VenueBooking.ViewModels.MyVenuesViewModel
@using VenueBooking.Models.Enums
@{
    ViewData["Title"] = "My Venues";
    Layout = "_OwnerLayout";
}

@Html.AntiForgeryToken()

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
    <div>
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900">My Venues</h2>
        <p class="text-slate-500 mt-1 text-sm">Manage and monitor your venue listings</p>
    </div>
    @if (Model.CanAddMoreVenues)
    {
        <a asp-action="CreateVenue" class="flex items-center gap-2 px-6 py-2.5 bg-primary text-white rounded-lg font-semibold hover:bg-primary/90 transition-all shadow-md shadow-primary/10 self-start sm:self-auto">
            <span class="material-symbols-outlined">add</span>
            <span>Add New Venue</span>
        </a>
    }
    else
    {
        <a asp-action="Subscription" class="flex items-center gap-2 px-6 py-2.5 bg-yellow-500 text-white rounded-lg font-semibold hover:bg-yellow-600 transition-all self-start sm:self-auto">
            <span class="material-symbols-outlined">upgrade</span>
            <span>Upgrade Plan</span>
        </a>
    }
</div>

<!-- Subscription Info Bar -->
<div class="bg-white p-4 rounded-xl border border-primary/10 mb-6 flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-4">
        <div class="p-3 bg-primary/10 rounded-lg text-primary">
            <span class="material-symbols-outlined">sell</span>
        </div>
        <div>
            <p class="text-sm text-slate-500">Current Plan</p>
            <p class="font-bold text-slate-900">@Model.CurrentPlanName</p>
        </div>
    </div>
    <div class="flex items-center gap-6">
        <div class="text-center">
            <p class="text-2xl font-bold text-primary">@Model.TotalVenues / @Model.MaxVenuesAllowed</p>
            <p class="text-xs text-slate-500">Venues Used</p>
        </div>
        <div class="w-px h-12 bg-slate-200"></div>
        <div class="text-center">
            <p class="text-2xl font-bold @(Model.SubscriptionDaysLeft <= 7 ? "text-red-600" : "text-secondary")">@Model.SubscriptionDaysLeft</p>
            <p class="text-xs text-slate-500">Days Left</p>
        </div>
    </div>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="bg-green-100 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined">check_circle</span>
        <span class="text-sm">@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="bg-red-100 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 flex items-center gap-2">
        <span class="material-symbols-outlined">error</span>
        <span class="text-sm">@TempData["Error"]</span>
    </div>
}

<!-- Search and Filter -->
<div class="bg-white p-4 rounded-xl border border-primary/5 mb-8 flex flex-col sm:flex-row gap-4 items-center">
    <div class="relative w-full sm:w-96">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
        <input type="text" id="searchVenues" class="w-full pl-10 pr-4 py-2.5 rounded-lg border-slate-200 focus:ring-primary focus:border-primary" placeholder="Search venues...">
    </div>
    <div class="flex bg-background-light p-1 rounded-lg">
        <button class="px-6 py-1.5 rounded-md text-sm font-semibold bg-white shadow-sm text-primary filter-btn" data-filter="all">All</button>
        <button class="px-6 py-1.5 rounded-md text-sm font-semibold text-slate-500 hover:text-slate-700 filter-btn" data-filter="live">Live</button>
        <button class="px-6 py-1.5 rounded-md text-sm font-semibold text-slate-500 hover:text-slate-700 filter-btn" data-filter="draft">Draft</button>
    </div>
</div>

<!-- Venue Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="venueGrid">
    @foreach (var venue in Model.Venues)
    {
        <div class="venue-card bg-white rounded-xl overflow-hidden border border-slate-100 shadow-sm hover:shadow-xl transition-shadow group" data-status="@(venue.IsActive ? "live" : "draft")">
            <div class="relative h-48 bg-slate-200 overflow-hidden">
                <img src="@venue.CoverImageUrl" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" alt="@venue.VenueName" onerror="this.src='/images/default-venue.jpg'">
                <div class="absolute top-3 left-3">
                    @if (venue.IsActive)
                    {
                        <span class="px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700 flex items-center gap-1 border border-green-200">
                            <span class="size-1.5 rounded-full bg-green-500"></span> LIVE
                        </span>
                    }
                    else
                    {
                        <span class="px-3 py-1 rounded-full text-xs font-bold bg-slate-100 text-slate-500 flex items-center gap-1 border border-slate-200">
                            <span class="size-1.5 rounded-full bg-slate-400"></span> DRAFT
                        </span>
                    }
                </div>
                @if (!venue.IsVerified)
                {
                    <div class="absolute top-3 right-3">
                        <span class="px-2 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-700 border border-yellow-200">Pending</span>
                    </div>
                }
            </div>
            <div class="p-5">
                <h3 class="text-lg font-bold mb-1 group-hover:text-primary transition-colors truncate">@venue.VenueName</h3>
                <div class="flex items-center gap-1 text-slate-500 text-sm mb-2">
                    <span class="material-symbols-outlined text-base">location_on</span>
                    <span class="truncate">@venue.City@(string.IsNullOrEmpty(venue.State) ? "" : $", {venue.State}")</span>
                </div>
                <div class="flex flex-wrap items-center gap-3 text-xs text-slate-400 mb-4">
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">group</span> @venue.Capacity
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">palette</span> @venue.ThemeCount
                    </span>
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">event</span> @venue.BookingCount
                    </span>
                </div>
                <div class="flex items-center gap-2 pt-4 border-t border-slate-50">
                    <a asp-action="EditVenue" asp-route-id="@venue.VenueId" class="size-10 flex items-center justify-center rounded-lg border border-slate-200 text-secondary hover:bg-slate-50 transition-colors" title="Edit">
                        <span class="material-symbols-outlined text-xl">edit</span>
                    </a>
                    <button onclick="toggleStatus(@venue.VenueId)" class="size-10 flex items-center justify-center rounded-lg border border-slate-200 @(venue.IsActive ? "text-green-600" : "text-slate-400") hover:bg-slate-50 transition-colors" title="@(venue.IsActive ? "Deactivate" : "Activate")">
                        <span class="material-symbols-outlined text-xl">@(venue.IsActive ? "visibility" : "visibility_off")</span>
                    </button>
                    <button onclick="deleteVenue(@venue.VenueId)" class="size-10 flex items-center justify-center rounded-lg border border-slate-200 text-red-500 hover:bg-red-50 transition-colors" title="Delete">
                        <span class="material-symbols-outlined text-xl">delete</span>
                    </button>
                </div>
            </div>
        </div>
    }

    @if (Model.CanAddMoreVenues)
    {
        <a asp-action="CreateVenue" class="flex flex-col items-center justify-center gap-4 h-full min-h-[350px] bg-primary/5 border-2 border-dashed border-primary/20 rounded-xl hover:bg-primary/10 transition-all group">
            <div class="size-14 rounded-full bg-white flex items-center justify-center text-primary shadow-sm group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-3xl">add</span>
            </div>
            <div class="text-center px-6">
                <p class="font-bold text-primary">Create New Venue</p>
                <p class="text-sm text-slate-500 mt-1">@Model.TotalVenues of @Model.MaxVenuesAllowed used</p>
            </div>
        </a>
    }
</div>

@section Scripts {
    <script>
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        document.getElementById('searchVenues').addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.venue-card').forEach(card => {
                const name = card.querySelector('h3')?.textContent.toLowerCase() || '';
                card.style.display = name.includes(term) ? '' : 'none';
            });
        });

        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('bg-white', 'shadow-sm', 'text-primary');
                    b.classList.add('text-slate-500');
                });
                this.classList.add('bg-white', 'shadow-sm', 'text-primary');
                this.classList.remove('text-slate-500');
                const filter = this.dataset.filter;
                document.querySelectorAll('.venue-card').forEach(card => {
                    card.style.display = (filter === 'all' || card.dataset.status === filter) ? '' : 'none';
                });
            });
        });

        function toggleStatus(venueId) {
            if (!confirm('Change this venue\'s status?')) return;
            fetch(`@Url.Action("ToggleVenueStatus", "Owner")/` + venueId, {
                method: 'POST',
                headers: { 'RequestVerificationToken': csrfToken }
            })
            .then(r => r.json())
            .then(data => { if (data.success) location.reload(); });
        }

        function deleteVenue(venueId) {
            if (!confirm('Delete this venue? This cannot be undone.')) return;
            fetch(`@Url.Action("DeleteVenue", "Owner")/` + venueId, {
                method: 'POST',
                headers: { 'RequestVerificationToken': csrfToken }
            })
            .then(() => location.reload());
        }
    </script>
}