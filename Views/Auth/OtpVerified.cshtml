@{
    ViewData["Title"] = "OTP Verified - VenueBooking";
}

<div class="bg-background-light min-h-screen flex flex-col">
    <!-- Main Content Area -->
    <main class="flex-1 flex items-center justify-center p-6">
        <div class="w-full max-w-md bg-white rounded-xl shadow-lg border border-slate-100 overflow-hidden">
            <!-- Success Content -->
            <div class="p-8 text-center">
                <!-- Large Success Icon -->
                <div class="mb-6 flex justify-center">
                    <div class="size-24 rounded-full flex items-center justify-center bg-secondary-sage/10">
                        <span class="material-symbols-outlined text-6xl text-secondary-sage">check_circle</span>
                    </div>
                </div>

                <!-- Text Block -->
                <h2 class="text-2xl font-bold text-slate-900 mb-3">OTP Verified Successfully!</h2>
                <p class="text-slate-500 leading-relaxed mb-8">
                    Your identity has been confirmed. You can now proceed to reset your password and secure your account.
                </p>

                <!-- CTA Button -->
                <div class="space-y-4">
                    <a href="/Auth/ResetPassword"
                       class="block w-full py-3.5 px-6 rounded-lg font-bold text-white bg-primary hover:opacity-90 transition-all active:scale-[0.98] shadow-lg shadow-primary/20 text-center">
                        Reset Password
                    </a>
                    <a href="/Auth/Login" class="block text-sm font-medium text-slate-500 hover:text-primary transition-colors py-2 underline underline-offset-4">
                        Back to Login
                    </a>
                </div>
            </div>

            <!-- Footer Progress -->
            <div class="bg-slate-50 px-8 py-4 border-t border-slate-100 flex items-center justify-center">
                <div class="flex flex-col items-center gap-3">
                    <div class="flex gap-2">
                        <div class="h-1.5 w-8 rounded-full bg-primary"></div>
                        <div class="h-1.5 w-8 rounded-full bg-primary"></div>
                        <div class="h-1.5 w-8 rounded-full bg-primary"></div>
                    </div>
                    <span class="text-[10px] font-bold text-slate-900 uppercase tracking-[0.2em]">Step 3 of 3</span>
                </div>
            </div>
        </div>
    </main>
</div>