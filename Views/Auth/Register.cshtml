@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="flex-grow flex items-center justify-center px-4 sm:px-6 lg:px-8 py-8 md:py-12 relative overflow-hidden">
    <div class="absolute top-[-10%] left-[-5%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-10%] right-[-5%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-3xl"></div>

    <div class="max-w-5xl w-full grid md:grid-cols-2 bg-white dark:bg-slate-900/50 rounded-xl shadow-2xl overflow-hidden z-10">
        <!-- Left Side: Visual Content -->
        <div class="hidden md:flex flex-col justify-between p-12 bg-secondary text-white relative overflow-hidden">
            <div class="z-10">
                <h2 class="text-4xl font-bold leading-tight mb-4">Discover the perfect space for your next memory.</h2>
                <p class="text-white/80 text-lg">Join thousands of planners who find and book exclusive venues effortlessly.</p>
            </div>
            <div class="mt-auto z-10">
                <div class="flex items-center gap-4 mb-6">
                    <div class="flex -space-x-3">
                        <div class="w-10 h-10 rounded-full border-2 border-secondary bg-slate-200 overflow-hidden">
                            <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=100 " alt="Customer 1" />
                        </div>
                        <div class="w-10 h-10 rounded-full border-2 border-secondary bg-slate-200 overflow-hidden">
                            <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=100 " alt="Customer 2" />
                        </div>
                        <div class="w-10 h-10 rounded-full border-2 border-secondary bg-slate-200 overflow-hidden">
                            <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=100 " alt="Customer 3" />
                        </div>
                    </div>
                    <span class="text-sm font-medium">Joined by 2,000+ hosts this month</span>
                </div>
            </div>
            <div class="absolute top-[-10%] right-[-10%] w-64 h-64 bg-accent/20 rounded-full blur-3xl"></div>
            <div class="absolute bottom-[-5%] left-[-5%] w-48 h-48 bg-primary/20 rounded-full blur-2xl"></div>
        </div>

        <!-- Right Side: Registration Form -->
        <div class="p-8 md:p-12 flex flex-col justify-center">
            <div class="mb-8">
                <h3 class="text-2xl font-bold text-text-main dark:text-white mb-2">Create Your Account</h3>
                <p class="text-slate-500 dark:text-slate-400 text-sm">Experience seamless event booking and management with Venue Vista.</p>
            </div>

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-red-500 text-sm mb-4">
                    @Html.ValidationSummary()
                </div>
            }

            <form action="/Auth/Register" method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                <!-- Full Name -->
                <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-text-main dark:text-slate-200">Full Name</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">person</span>
                        <input name="Name" type="text" required maxlength="100"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-text-main dark:text-white placeholder:text-slate-400"
                               placeholder="e.g. John Doe" />
                    </div>
                </div>

                <!-- Email -->
                <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-text-main dark:text-slate-200">Email Address</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">mail</span>
                        <input name="Email" type="email" required maxlength="150"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-text-main dark:text-white placeholder:text-slate-400"
                               placeholder="john@example.com" />
                    </div>
                </div>

                <!-- Phone -->
                <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-text-main dark:text-slate-200">Phone Number</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">call</span>
                        <input name="Phone" type="tel" maxlength="20"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-text-main dark:text-white placeholder:text-slate-400"
                               placeholder="+91 98765 43210" />
                    </div>
                </div>

                <!-- Password (PasswordHash) -->
                <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-text-main dark:text-slate-200">Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock</span>
                        <input name="PasswordHash" type="password" required maxlength="255"
                               class="w-full pl-10 pr-12 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-text-main dark:text-white placeholder:text-slate-400"
                               placeholder="••••••••" />
                        <button type="button" onclick="togglePassword('PasswordHash', 'eye-icon-1')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl" id="eye-icon-1">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Confirm Password (Password) -->
                <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-text-main dark:text-slate-200">Confirm Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">lock_clock</span>
                        <input name="Password" type="password" required maxlength="255"
                               class="w-full pl-10 pr-12 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-text-main dark:text-white placeholder:text-slate-400"
                               placeholder="••••••••" />
                        <button type="button" onclick="togglePassword('Password', 'eye-icon-2')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl" id="eye-icon-2">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Terms -->
                <div class="flex items-start gap-2 pt-2">
                    <input name="AcceptTerms" type="checkbox" value="true" required
                           class="mt-1 rounded border-slate-300 text-primary focus:ring-primary" />
                    <label class="text-xs text-slate-500 dark:text-slate-400 leading-normal">
                        I agree to the <a href="#" class="text-primary hover:underline">Terms of Service</a> and <a href="#" class="text-primary hover:underline">Privacy Policy</a>.
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3.5 rounded-lg transition-all shadow-md active:scale-[0.98] flex items-center justify-center gap-2 mt-2">
                    Register Now
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                </button>

                <!-- Divider -->
                <div class="relative py-4">
                    <div class="absolute inset-0 flex items-center">
                        <span class="w-full border-t border-slate-100 dark:border-slate-700"></span>
                    </div>
                    <div class="relative flex justify-center text-xs uppercase">
                        <span class="bg-white dark:bg-slate-900 px-2 text-slate-400 font-medium">Already have an account?</span>
                    </div>
                </div>

                <!-- Login Link -->
                <a href="/Auth/Login" class="w-full border border-secondary text-secondary hover:bg-secondary/5 dark:text-secondary dark:hover:bg-secondary/10 font-bold py-3 rounded-lg transition-all flex items-center justify-center">
                    Login to Account
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            var passwordInput = document.getElementById(inputId);
            var eyeIcon = document.getElementById(iconId);
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                eyeIcon.textContent = 'visibility_off';
            } else {
                passwordInput.type = 'password';
                eyeIcon.textContent = 'visibility';
            }
        }
    </script>
}