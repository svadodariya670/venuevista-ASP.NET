@model VenueBooking.ViewModels.AdminBookingsViewModel
@{
    ViewData["Title"] = "Bookings Management";
    Layout = "_AdminLayout";
}

<div class="max-w-[1400px] mx-auto">
    <!-- Header -->
    <div class="mb-8 flex items-end justify-between">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">Bookings Management</h2>
            <p class="text-slate-500 mt-1">Track and manage all venue bookings</p>
        </div>
        <button class="bg-primary text-white px-4 py-2 rounded-xl text-sm font-bold shadow-lg shadow-primary/30 hover:bg-primary/90 flex items-center gap-2">
            <span class="material-symbols-outlined text-lg">add</span>
            Create Booking
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 mb-8">
        <div class="bg-card-bg dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-blue-50 dark:bg-blue-900/20 text-blue-600 rounded-lg">
                    <span class="material-symbols-outlined">bookmark</span>
                </div>
            </div>
            <p class="text-sm font-medium text-slate-500">Total Bookings</p>
            <h3 class="text-2xl font-bold mt-1 text-slate-900 dark:text-white">@Model.TotalBookings</h3>
        </div>
        <div class="bg-card-bg dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 rounded-lg">
                    <span class="material-symbols-outlined">check_circle</span>
                </div>
            </div>
            <p class="text-sm font-medium text-slate-500">Confirmed</p>
            <h3 class="text-2xl font-bold mt-1 text-slate-900 dark:text-white">@Model.ConfirmedBookings</h3>
        </div>
        <div class="bg-card-bg dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-amber-50 dark:bg-amber-900/20 text-amber-600 rounded-lg">
                    <span class="material-symbols-outlined">pending</span>
                </div>
            </div>
            <p class="text-sm font-medium text-slate-500">Pending</p>
            <h3 class="text-2xl font-bold mt-1 text-slate-900 dark:text-white">@Model.PendingBookings</h3>
        </div>
        <div class="bg-card-bg dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-purple-50 dark:bg-purple-900/20 text-purple-600 rounded-lg">
                    <span class="material-symbols-outlined">event_available</span>
                </div>
            </div>
            <p class="text-sm font-medium text-slate-500">This Month</p>
            <h3 class="text-2xl font-bold mt-1 text-slate-900 dark:text-white">@Model.ThisMonthBookings</h3>
        </div>
        <div class="bg-card-bg dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="p-2 bg-primary/10 text-primary rounded-lg">
                    <span class="material-symbols-outlined">payments</span>
                </div>
            </div>
            <p class="text-sm font-medium text-slate-500">Total Revenue</p>
            <h3 class="text-2xl font-bold mt-1 text-slate-900 dark:text-white">@Model.TotalRevenue.ToString("C0")</h3>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-card-bg dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm mb-6">
        <div class="flex flex-col md:flex-row gap-4 justify-between">
            <div class="flex gap-4 flex-1">
                <div class="relative flex-1 max-w-md">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input type="text" id="searchBookings" placeholder="Search booking ID, customer or venue..."
                           class="w-full pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" />
                </div>
                <select id="statusFilter" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20">
                    <option value="All">All Status</option>
                    <option value="Pending">Pending</option>
                    <option value="Contacted">Contacted</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
                <input type="date" class="px-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="Filter by date" />
            </div>
        </div>
    </div>

    <!-- Bookings Table -->
    <div class="bg-card-bg dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 dark:bg-slate-800/50 text-slate-500 text-xs font-bold uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Booking ID</th>
                        <th class="px-6 py-4">Customer</th>
                        <th class="px-6 py-4">Venue</th>
                        <th class="px-6 py-4">Event Date</th>
                        <th class="px-6 py-4">Event Type</th>
                        <th class="px-6 py-4">Amount</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Payment</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @foreach (var booking in Model.Bookings)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                            <td class="px-6 py-4">
                                <p class="text-sm font-bold text-slate-900 dark:text-white">#@booking.BookingId</p>
                                <p class="text-xs text-slate-500">@booking.CreatedAt.ToString("MMM dd, yyyy")</p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="size-8 rounded-full bg-secondary/10 text-secondary flex items-center justify-center font-bold text-xs">
                                        @booking.CustomerInitials
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-slate-900 dark:text-white">@booking.CustomerName</p>
                                        <p class="text-xs text-slate-500">@booking.CustomerEmail</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm font-medium text-slate-900 dark:text-white">@booking.VenueName</p>
                                <p class="text-xs text-slate-500">@booking.OwnerName</p>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm text-slate-600 dark:text-slate-300">@booking.StartDate.ToString("MMM dd, yyyy")</p>
                                <p class="text-xs text-slate-500">@booking.StartDate.ToString("HH:mm") - @booking.EndDate.ToString("HH:mm")</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-md bg-primary/10 text-primary text-xs font-bold">
                                    @booking.EventType
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm font-bold text-slate-900 dark:text-white">@booking.TotalPrice.ToString("C")</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 rounded-md text-xs font-bold
                                        @(booking.Status == BookingStatus.Confirmed ? "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600" :
                                                                            booking.Status == BookingStatus.Pending ? "bg-amber-100 dark:bg-amber-900/30 text-amber-600" :
                                                                            booking.Status == BookingStatus.Completed ? "bg-blue-100 dark:bg-blue-900/30 text-blue-600" :
                                                                            booking.Status == BookingStatus.Cancelled ? "bg-red-100 dark:bg-red-900/30 text-red-600" :
                                                                            "bg-slate-100 dark:bg-slate-800 text-slate-600")">
                                                                                                                          @booking.Status
                                                                                                                      </span>
                                                                                                                  </td>
                                                                                                                  <td class="px-6 py-4">
                                                                                                                      <span class="px-2 py-1 rounded-md text-xs font-bold
                                        @(booking.PaymentStatus == PaymentStatus.Completed ? "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600" :
                                                                            booking.PaymentStatus == PaymentStatus.Pending ? "bg-amber-100 dark:bg-amber-900/30 text-amber-600" :
                                                                            "bg-slate-100 dark:bg-slate-800 text-slate-600")">
                                @booking.PaymentStatus
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <a asp-action="BookingDetails" asp-route-id="@booking.BookingId"
                                   class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all" title="View">
                                    <span class="material-symbols-outlined text-lg">visibility</span>
                                </a>
                                @if (booking.Status == BookingStatus.Pending)
                                    {
                                        <button onclick="updateStatus(@booking.BookingId, 'Contacted')"
                                                class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all" title="Mark Contacted">
                                            <span class="material-symbols-outlined text-lg">phone</span>
                                        </button>
                                    }
                                    @if (booking.Status == BookingStatus.Contacted)
                                    {
                                        <button onclick="updateStatus(@booking.BookingId, 'Confirmed')"
                                                class="p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-all" title="Confirm">
                                            <span class="material-symbols-outlined text-lg">check</span>
                                        </button>
                                    }
                                    <button class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all" title="Cancel">
                                        <span class="material-symbols-outlined text-lg">close</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateStatus(bookingId, status) {
            fetch(`/Admin/UpdateBookingStatus`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ bookingId, status })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) location.reload();
            });
        }
    </script>
}