<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Venue Vista</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL@20..48,100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#C65D3B",
                        secondary: "#4A5D52",
                        "background-light": "#FDF8F3",
                        "background-dark": "#1f1613",
                        "text-main": "#2C2C2C",
                    },
                    fontFamily: {
                        sans: ["Inter", "sans-serif"],
                        display: ["Poppins", "sans-serif"]
                    },
                },
            },
        }
    </script>

    <!-- Custom Styles -->
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

            .material-symbols-outlined.fill-current {
                font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-text-main dark:text-slate-100 antialiased">

    <!-- Header -->
    <header class="sticky top-0 z-50 w-full border-b border-primary/10 bg-[#FDF8F3]/90 dark:bg-background-dark/90 backdrop-blur-md">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-2 text-primary">
                <span class="material-symbols-outlined text-3xl font-bold">location_away</span>
                <h1 class="text-xl font-extrabold tracking-tight text-[#2C2C2C] dark:text-white font-display">Venue Vista</h1>
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden md:flex items-center gap-8">
                <a class="text-sm font-semibold hover:text-primary transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "text-primary" : "")" href="/">Home</a>
                <a class="text-sm font-semibold hover:text-primary transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "About" ? "text-primary" : "")" href="/Home/About">About</a>
                <a class="text-sm font-semibold hover:text-primary transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "Contact" ? "text-primary" : "")" href="/Home/Contact">Contact</a>
                <a class="text-sm font-semibold hover:text-primary transition-colors @(ViewContext.RouteData.Values["action"]?.ToString() == "FAQ" ? "text-primary" : "")" href="/Home/FAQ">FAQ</a>
            </nav>

            <!-- Desktop Auth Buttons -->
            <div class="hidden md:flex items-center gap-3">
                <a href="/Auth/Login" class="border border-primary/20 bg-transparent px-5 py-2 text-sm font-bold text-[#2C2C2C] hover:bg-primary/5 dark:text-white rounded-lg transition-colors">
                    Login
                </a>
                <a href="/Auth/Register" class="border border-primary/20 bg-transparent px-5 py-2 text-sm font-bold text-[#2C2C2C] hover:bg-primary/5 dark:text-white rounded-lg transition-colors">
                    Register
                </a>
                <a href="/Auth/JoinNow" class="bg-primary px-5 py-2 text-sm font-bold text-white shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all rounded-lg">
                    Join as Owner
                </a>
            </div>

            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 text-text-main dark:text-white">
                <span class="material-symbols-outlined text-3xl">menu</span>
            </button>
        </div>

        <!-- Mobile Menu (Hidden by default) -->
        <div id="mobile-menu" class="hidden md:hidden bg-[#FDF8F3] dark:bg-background-dark border-t border-primary/10">
            <div class="px-6 py-4 space-y-4">
                <a href="/" class="block text-base font-semibold text-text-main dark:text-white hover:text-primary transition-colors py-2">Home</a>
                <a href="/Home/About" class="block text-base font-semibold text-text-main dark:text-white hover:text-primary transition-colors py-2">About</a>
                <a href="/Home/Contact" class="block text-base font-semibold text-text-main dark:text-white hover:text-primary transition-colors py-2">Contact</a>
                <a href="/Home/FAQ" class="block text-base font-semibold text-text-main dark:text-white hover:text-primary transition-colors py-2">FAQ</a>
                <hr class="border-slate-200 dark:border-slate-700" />
                <a href="/Auth/Login" class="block text-base font-semibold text-text-main dark:text-white hover:text-primary transition-colors py-2">Login</a>
                <a href="/Auth/JoinNow" class="block text-base font-semibold text-primary hover:text-primary/80 transition-colors py-2">Join as Owner</a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 bg-[#FDF8F3] py-16 dark:border-slate-800 dark:bg-background-dark">
        <div class="mx-auto max-w-7xl px-6">
            <div class="grid grid-cols-1 gap-12 md:grid-cols-4">
                <!-- Brand -->
                <div class="col-span-1 md:col-span-1">
                    <div class="flex items-center gap-2 text-primary">
                        <span class="material-symbols-outlined text-2xl font-bold">location_away</span>
                        <h1 class="text-lg font-extrabold tracking-tight text-[#2C2C2C] dark:text-white font-display">Venue Vista</h1>
                    </div>
                    <p class="mt-6 text-sm leading-relaxed text-slate-500 dark:text-slate-400">
                        The ultimate destination for finding and booking unique venues for weddings, parties, and corporate events.
                    </p>
                    <div class="mt-6 flex gap-4">
                        <a class="flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-sm text-slate-600 hover:bg-primary hover:text-white dark:bg-slate-800 dark:text-slate-400 transition-colors" href="#">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" /></svg>
                        </a>
                        <a class="flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-sm text-slate-600 hover:bg-primary hover:text-white dark:bg-slate-800 dark:text-slate-400 transition-colors" href="#">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.245 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.063 1.366-.33 2.633-1.308 3.608-.975.975-2.242 1.245-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.063-2.633-.33-3.608-1.308-.975-.975-1.245-2.242-1.308-3.608-.058-1.266-.07-1.646-.07-4.85s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.245 3.608-1.308 1.266-.058 1.646-.07 4.85-.07zm0-2.163c-3.259 0-3.667.014-4.947.072-1.362.06-2.503.31-3.447 1.254-.944.944-1.194 2.085-1.254 3.447-.058 1.28-.072 1.688-.072 4.947s.014 3.668.072 4.947c.06 1.362.31 2.503 1.254 3.447.944.944 2.085 1.194 3.447 1.254 1.28.058 1.688.072 4.947.072s3.668-.014 4.947-.072c1.362-.06 2.503-.31 3.447-1.254.944-.944 1.194-2.085 1.254-3.447.058-1.28.072-1.688.072-4.947s-.014-3.668-.072-4.947c-.06-1.362-.31-2.503-1.254-3.447-.944-.944-1.194-2.085-1.254-3.447-.058-1.28-.072-1.688-.072-4.947z" /><circle cx="12" cy="12" r="5.838" /><circle cx="18.406" cy="5.594" r="1.44" /></svg>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div>
                    <h5 class="font-bold text-text-main dark:text-white font-display">Quick Links</h5>
                    <ul class="mt-6 space-y-4 text-sm font-medium text-slate-500 dark:text-slate-400">
                        <li><a class="hover:text-primary transition-colors" href="/">Home</a></li>
                        <li><a class="hover:text-primary transition-colors" href="/Venues">Browse Venues</a></li>
                        <li><a class="hover:text-primary transition-colors" href="/Auth/JoinNow">Join as Owner</a></li>
                        <li><a class="hover:text-primary transition-colors" href="/Pricing">Pricing</a></li>
                    </ul>
                </div>

                <!-- Support -->
                <div>
                    <h5 class="font-bold text-text-main dark:text-white font-display">Support</h5>
                    <ul class="mt-6 space-y-4 text-sm font-medium text-slate-500 dark:text-slate-400">
                        <li><a class="hover:text-primary transition-colors" href="/Home/About">About Us</a></li>
                        <li><a class="hover:text-primary transition-colors" href="/Home/Contact">Contact Support</a></li>
                        <li><a class="hover:text-primary transition-colors" href="/Home/FAQ">FAQ</a></li>
                        <li><a class="hover:text-primary transition-colors" href="/Privacy">Privacy Policy</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div>
                    <h5 class="font-bold text-text-main dark:text-white font-display">Contact</h5>
                    <ul class="mt-6 space-y-4 text-sm font-medium text-slate-500 dark:text-slate-400">
                        <li class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm text-primary">mail</span>
                            hello@venuevista.com
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm text-primary">call</span>
                            +91 98765 43210
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm text-primary">location_on</span>
                            Mumbai, India
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Copyright -->
            <div class="mt-16 border-t border-slate-100 pt-8 text-center text-xs font-medium text-slate-400 dark:border-slate-800">
                © 2026 Venue Vista. All rights reserved. Designed for excellence.
            </div>
        </div>
    </footer>

    <!-- Mobile Menu Toggle Script -->
    <script>
        document.getElementById('mobile-menu-btn').addEventListener('click', function() {
            var menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        });
    </script>

    <!-- Scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>