@{
    ViewData["Title"] = "About Us";
}

<!-- Use a unified container for the content so we get standard equal margins -->
<div class="mx-auto max-w-7xl px-6 py-12 md:py-20">

    <!-- Hero Section -->
    <section class="grid lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
            <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-primary mb-4">Our Journey</span>
            <h1 class="text-4xl md:text-5xl font-black text-text-main dark:text-white leading-tight mb-6 font-display">
                Making venue booking <span class="text-primary">seamless</span>
            </h1>
            <p class="text-slate-600 dark:text-slate-400 text-lg leading-relaxed mb-8">
                Our journey started with a simple goal: to eliminate the frustration of manual bookings and help you find the perfect space for every occasion. We believe that finding a venue should be as exciting as the event itself.
            </p>
            <div class="flex flex-wrap gap-4">
                <a href="#our-team" class="bg-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-primary/90 transition-all">Read Full Story</a>
                <a href="/Home/Search" class="border border-slate-300 dark:border-slate-700 text-text-main dark:text-white px-6 py-3 rounded-lg font-bold hover:bg-slate-100 dark:hover:bg-slate-800 transition-all">View Portfolio</a>
            </div>
        </div>
        <div class="relative">
            <img src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3?auto=format&fit=crop&q=80&w=800"
                 alt="Elegant venue interior"
                 class="rounded-2xl shadow-2xl w-full object-cover h-[400px]" />
        </div>
    </section>

    <!-- Stats Section -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        <div class="bg-white dark:bg-slate-800/50 p-8 rounded-xl border border-slate-100 dark:border-slate-700 text-center shadow-sm">
            <p class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Venues</p>
            <p class="text-4xl font-black text-text-main dark:text-white mb-2 font-display">1000+</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Curated spaces worldwide</p>
        </div>
        <div class="bg-white dark:bg-slate-800/50 p-8 rounded-xl border border-slate-100 dark:border-slate-700 text-center shadow-sm">
            <p class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Happy Customers</p>
            <p class="text-4xl font-black text-text-main dark:text-white mb-2 font-display">50k+</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Memorable events hosted</p>
        </div>
        <div class="bg-white dark:bg-slate-800/50 p-8 rounded-xl border border-slate-100 dark:border-slate-700 text-center shadow-sm">
            <p class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Cities</p>
            <p class="text-4xl font-black text-text-main dark:text-white mb-2 font-display">10+</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Expanding global presence</p>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="grid md:grid-cols-2 gap-6 mb-20">
        <div class="bg-primary p-8 md:p-10 rounded-2xl text-white shadow-lg">
            <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mb-6 backdrop-blur-sm">
                <span class="material-symbols-outlined text-2xl">rocket_launch</span>
            </div>
            <h3 class="text-2xl font-bold mb-4 font-display">Our Mission</h3>
            <p class="text-white/90 leading-relaxed">
                To empower event planners and venue owners through intuitive technology, creating a seamless bridge between vision and reality.
            </p>
        </div>
        <div class="bg-white dark:bg-slate-800/50 p-8 md:p-10 rounded-2xl border border-slate-100 dark:border-slate-700 shadow-sm">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-2xl text-primary">visibility</span>
            </div>
            <h3 class="text-2xl font-bold mb-4 font-display text-text-main dark:text-white">Our Vision</h3>
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                To be the world's most trusted platform for discovering and booking unique spaces, making every event extraordinary.
            </p>
        </div>
    </section>

    <!-- Team Section -->
    <section id="our-team" class="text-center mb-20 pt-10 scroll-m-20">
        <h2 class="text-3xl font-black text-text-main dark:text-white mb-4 font-display">The people behind the vision</h2>
        <p class="text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-12">
            Meet the dedicated team working around the clock to revolutionize how you find and book event spaces.
        </p>

        <div class="grid md:grid-cols-3 gap-8">
            <!-- Team Member 1 -->
            <div class="text-center group">
                <div class="relative mb-4 mx-auto w-48 h-48 overflow-hidden rounded-2xl">
                    <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80&w=400"
                         alt="Arjun Patel"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <h4 class="font-bold text-text-main dark:text-white text-lg">Arjun Patel</h4>
                <p class="text-primary text-sm font-medium mb-3">Founder & CEO</p>
            </div>

            <!-- Team Member 2 -->
            <div class="text-center group">
                <div class="relative mb-4 mx-auto w-48 h-48 overflow-hidden rounded-2xl">
                    <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=400"
                         alt="Siya Rao"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <h4 class="font-bold text-text-main dark:text-white text-lg">Siya Rao</h4>
                <p class="text-primary text-sm font-medium mb-3">Chief Technology Officer</p>
            </div>

            <!-- Team Member 3 -->
            <div class="text-center group">
                <div class="relative mb-4 mx-auto w-48 h-48 overflow-hidden rounded-2xl">
                    <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&q=80&w=400"
                         alt="Parth Patel"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <h4 class="font-bold text-text-main dark:text-white text-lg">Parth Patel</h4>
                <p class="text-primary text-sm font-medium mb-3">Head of Operations</p>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-secondary rounded-3xl p-8 md:p-16 text-center text-white relative overflow-hidden shadow-2xl">
        <div class="absolute top-0 right-0 -mr-24 -mt-24 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
        <div class="relative z-10">
            <h2 class="text-3xl md:text-4xl font-black mb-4 font-display">Ready to book your next venue?</h2>
            <p class="text-white/80 text-lg mb-8 max-w-xl mx-auto">
                Join thousands of happy customers who found their perfect event space with Venue Vista.
            </p>
            <a href="/Auth/Register" class="inline-block bg-primary text-white px-8 py-4 rounded-lg font-bold hover:bg-primary/90 shadow-lg shadow-primary/30 transition-all active:scale-95">
                Get Started for Free
            </a>
        </div>
    </section>
</div>