@{
    ViewData["Title"] = "Contact Us";
}

<!-- Hero Header Section -->
<div class="text-center mb-16">
    <h1 class="text-slate-900 dark:text-slate-100 text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4">
        Get in Touch
    </h1>
    <p class="text-slate-600 dark:text-slate-400 text-lg max-w-2xl mx-auto">
        We'd love to hear from you. Whether you have a question about venues, pricing, or anything else, our team is ready to answer all your questions.
    </p>
</div>

<!-- Content Grid -->
<div class="grid lg:grid-cols-5 gap-12 items-start">
    <!-- Left Side: Contact Information -->
    <div class="lg:col-span-2 space-y-8">
        <div class="bg-primary/5 dark:bg-primary/10 p-8 rounded-xl border border-primary/10">
            <h2 class="text-2xl font-bold mb-8 text-slate-900 dark:text-slate-100">Contact Information</h2>
            <div class="space-y-8">
                <!-- Email -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary text-white rounded-lg p-3 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">mail</span>
                    </div>
                    <div>
                        <p class="text-slate-900 dark:text-slate-100 font-bold mb-1">Email Us</p>
                        <p class="text-slate-600 dark:text-slate-400">hello@venuevista.com</p>
                        <p class="text-primary text-sm mt-1 font-medium">Response within 24 hours</p>
                    </div>
                </div>
                <!-- Phone -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary text-white rounded-lg p-3 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">call</span>
                    </div>
                    <div>
                        <p class="text-slate-900 dark:text-slate-100 font-bold mb-1">Call Us</p>
                        <p class="text-slate-600 dark:text-slate-400">+91 98765 43210</p>
                        <p class="text-slate-500 text-xs mt-1 italic">Mon-Sat, 9am - 6pm IST</p>
                    </div>
                </div>
                <!-- Address -->
                <div class="flex items-start gap-4">
                    <div class="bg-primary text-white rounded-lg p-3 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">location_on</span>
                    </div>
                    <div>
                        <p class="text-slate-900 dark:text-slate-100 font-bold mb-1">Visit Office</p>
                        <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
                            Level 4, Business Bay, Lower Parel,<br />
                            Mumbai, Maharashtra 400013, India
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Map/Visual Element -->
        <div class="relative overflow-hidden rounded-xl h-48 group shadow-md border border-slate-200 dark:border-slate-800">
            <img alt="Location Map" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                 src="https://images.unsplash.com/photo-1524661135-423995f22d0b?auto=format&fit=crop&q=80&w=800" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end p-4">
                <span class="text-white font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">map</span>
                    View on Maps
                </span>
            </div>
        </div>
    </div>

    <!-- Right Side: Contact Form -->
    <div class="lg:col-span-3 bg-white dark:bg-slate-900/50 p-8 md:p-10 rounded-xl shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-100 dark:border-slate-800">
        
        <!-- ACTION NOTIFICATIONS ADDED HERE -->
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 p-4 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-400 rounded-lg flex items-center gap-3 shadow-sm">
                <span class="material-symbols-outlined shrink-0 text-emerald-500">check_circle</span>
                <p class="text-sm font-medium">@TempData["Success"]</p>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 rounded-lg flex items-center gap-3 shadow-sm">
                <span class="material-symbols-outlined shrink-0 text-red-500">error</span>
                <p class="text-sm font-medium">@TempData["Error"]</p>
            </div>
        }
        <!-- END ACTION NOTIFICATIONS -->

        <form asp-controller="Home" asp-action="Contact" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div class="grid md:grid-cols-2 gap-6">
                <!-- Name Field -->
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300" for="name">Full Name</label>
                    <input name="name" id="name" type="text" required
                           class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary focus:border-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600"
                           placeholder="Manoj Kumar" />
                </div>
                <!-- Email Field -->
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 dark:text-slate-300" for="email">Email Address</label>
                    <input name="email" id="email" type="email" required
                           class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary focus:border-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600"
                           placeholder="Manoj@example.com" />
                </div>
            </div>

            <!-- Subject Field -->
            <div class="space-y-2">
                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300" for="subject">Subject</label>
                <input name="subject" id="subject" type="text" required
                       class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary focus:border-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600"
                       placeholder="Venue Inquiry" />
            </div>

            <!-- Message Field -->
            <div class="space-y-2">
                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300" for="message">How can we help you?</label>
                <textarea name="message" id="message" rows="5" required
                          class="w-full px-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-transparent focus:ring-2 focus:ring-primary focus:border-primary transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600 resize-none"
                          placeholder="Tell us more about your event..."></textarea>
            </div>

            <!-- Submit Button -->
            <div>
                <button type="submit"
                        class="w-full md:w-auto min-w-[180px] bg-primary text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all flex items-center justify-center gap-2 group active:scale-95">
                    <span>Send Message</span>
                    <span class="material-symbols-outlined transition-transform group-hover:translate-x-1">send</span>
                </button>
            </div>
        </form>
    </div>
</div>