@model VenueBooking.ViewModels.VenueSearchViewModel
@{
    ViewData["Title"] = "Browse Venues";
    Layout = "_CustomerLayout";
    var searchTerm = ViewBag.Search as string ?? "";
}

<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl sm:text-3xl font-black tracking-tight text-slate-900">Browse Venues</h1>
        <p class="text-slate-500 mt-1 text-sm">@Model.TotalResults active & approved venues available</p>
    </div>

    <!-- Search & Filters -->
    <form method="get" asp-action="BrowseVenues" class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 sm:p-5 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Search</label>
                <input type="text" name="search" value="@searchTerm" placeholder="Venue name..."
                       class="w-full px-3 py-2.5 bg-slate-50 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/20" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">City</label>
                <select name="city" class="w-full px-3 py-2.5 bg-slate-50 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/20">
                    <option value="All">All Cities</option>
                    @foreach (var c in Model.AvailableCities)
                    {
                        <option value="@c" selected="@(Model.City == c)">@c</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Type</label>
                <select name="type" class="w-full px-3 py-2.5 bg-slate-50 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/20">
                    <option value="All">All Types</option>
                    @foreach (var t in Model.AvailableTypes)
                    {
                        <option value="@t" selected="@(Model.VenueType == t)">@t</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Min Guests</label>
                <input type="number" name="guests" value="@Model.Guests" placeholder="Any" min="1"
                       class="w-full px-3 py-2.5 bg-slate-50 border-none rounded-lg text-sm focus:ring-2 focus:ring-primary/20" />
            </div>
            <div class="flex items-end gap-2">
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-bold hover:bg-primary/90 transition-colors flex items-center justify-center gap-1">
                    <span class="material-symbols-outlined text-lg">search</span>
                    Search
                </button>
                <a asp-action="BrowseVenues" class="px-3 py-2.5 border border-slate-200 rounded-lg text-sm text-slate-500 hover:bg-slate-50 transition-colors">
                    <span class="material-symbols-outlined text-lg">refresh</span>
                </a>
            </div>
        </div>
    </form>

    <!-- Results -->
    @if (Model.Venues.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            @foreach (var venue in Model.Venues)
            {
                <a asp-action="VenueDetails" asp-route-id="@venue.VenueId"
                   class="group bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-lg hover:border-primary/20 transition-all">
                    <!-- Image -->
                    <div class="relative h-44 overflow-hidden">
                        <img src="@venue.CoverImageUrl" alt="@venue.VenueName"
                             class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                             onerror="this.src='/images/default-venue.jpg'" />
                        <div class="absolute top-3 left-3 px-2.5 py-1 bg-white/90 backdrop-blur-sm rounded-lg text-xs font-bold text-primary shadow-sm">
                            @venue.City
                        </div>
                        @if (venue.AverageRating > 0)
                        {
                            <div class="absolute top-3 right-3 px-2 py-1 bg-black/60 backdrop-blur-sm rounded-lg flex items-center gap-1">
                                <span class="material-symbols-outlined text-amber-400 text-sm">star</span>
                                <span class="text-white text-xs font-bold">@venue.AverageRating</span>
                            </div>
                        }
                    </div>
                    <!-- Info -->
                    <div class="p-4">
                        <h3 class="text-lg font-bold text-slate-900 truncate group-hover:text-primary transition-colors">@venue.VenueName</h3>
                        <div class="flex items-center gap-3 mt-2 text-sm text-slate-500">
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">groups</span>
                                @venue.Capacity
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">category</span>
                                @venue.VenueType
                            </span>
                            @if (venue.ReviewCount > 0)
                            {
                                <span class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-sm">rate_review</span>
                                    @venue.ReviewCount
                                </span>
                            }
                        </div>
                        <div class="mt-3 pt-3 border-t border-slate-100 flex items-center justify-between">
                            @if (venue.StartingPrice > 0)
                            {
                                <div>
                                    <span class="text-xl font-black text-primary">₹@venue.StartingPrice.ToString("N0")</span>
                                    <span class="text-xs text-slate-400">/day</span>
                                </div>
                            }
                            else
                            {
                                <span class="text-sm text-slate-400">Contact for price</span>
                            }
                            <span class="px-3 py-1.5 bg-primary/10 text-primary text-xs font-bold rounded-lg group-hover:bg-primary group-hover:text-white transition-colors">
                                View Details
                            </span>
                        </div>
                    </div>
                </a>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="mt-8 flex justify-center gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-action="BrowseVenues" asp-route-page="@(Model.CurrentPage - 1)" asp-route-city="@Model.City" asp-route-type="@Model.VenueType" asp-route-guests="@Model.Guests" asp-route-search="@searchTerm"
                       class="px-4 py-2 rounded-lg border border-slate-200 text-sm font-medium hover:bg-slate-50 transition-colors">
                        ← Prev
                    </a>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="BrowseVenues" asp-route-page="@i" asp-route-city="@Model.City" asp-route-type="@Model.VenueType" asp-route-guests="@Model.Guests" asp-route-search="@searchTerm"
                       class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(i == Model.CurrentPage ? "bg-primary text-white" : "border border-slate-200 hover:bg-slate-50")">
                        @i
                    </a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-action="BrowseVenues" asp-route-page="@(Model.CurrentPage + 1)" asp-route-city="@Model.City" asp-route-type="@Model.VenueType" asp-route-guests="@Model.Guests" asp-route-search="@searchTerm"
                       class="px-4 py-2 rounded-lg border border-slate-200 text-sm font-medium hover:bg-slate-50 transition-colors">
                        Next →
                    </a>
                }
            </div>
        }
    }
    else
    {
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-12 text-center">
            <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">search_off</span>
            <h3 class="text-xl font-bold text-slate-700">No Venues Found</h3>
            <p class="text-slate-500 mt-2">Try adjusting your filters or search terms.</p>
            <a asp-action="BrowseVenues" class="inline-block mt-4 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition-colors">
                Clear Filters
            </a>
        </div>
    }
</div>