@model VenueBooking.ViewModels.CustomerDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_CustomerLayout";
    var userName = Context.Session.GetString("UserName") ?? "Customer";
}

<div class="space-y-8 max-w-7xl mx-auto">
    <!-- Welcome -->
    <div>
        <h2 class="text-3xl font-bold text-slate-900">Welcome back, @userName!</h2>
        <p class="text-slate-500 mt-1">Manage your bookings and explore new venues.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <p class="text-sm font-medium text-emerald-800">@TempData["Success"]</p>
        </div>
    }

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
            <div class="size-12 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">event_available</span>
            </div>
            <div>
                <p class="text-sm text-slate-500">Upcoming</p>
                <p class="text-2xl font-bold text-slate-900">@Model.UpcomingBookings</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
            <div class="size-12 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600">
                <span class="material-symbols-outlined">hourglass_top</span>
            </div>
            <div>
                <p class="text-sm text-slate-500">Pending</p>
                <p class="text-2xl font-bold text-slate-900">@Model.PendingBookings</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
            <div class="size-12 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                <span class="material-symbols-outlined">check_circle</span>
            </div>
            <div>
                <p class="text-sm text-slate-500">Completed</p>
                <p class="text-2xl font-bold text-slate-900">@Model.CompletedBookings</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center gap-4">
            <div class="size-12 rounded-lg bg-purple-50 flex items-center justify-center text-purple-600">
                <span class="material-symbols-outlined">payments</span>
            </div>
            <div>
                <p class="text-sm text-slate-500">Total Spent</p>
                <p class="text-2xl font-bold text-slate-900">₹@Model.TotalSpent.ToString("N0")</p>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a asp-action="Bookings" class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm hover:shadow-md hover:border-primary/30 transition-all flex items-center gap-4 group">
            <div class="size-10 rounded-lg bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                <span class="material-symbols-outlined">calendar_today</span>
            </div>
            <div>
                <p class="font-bold text-slate-900">My Bookings</p>
                <p class="text-xs text-slate-500">@Model.TotalBookings total bookings</p>
            </div>
        </a>
        <a asp-action="Messages" class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm hover:shadow-md hover:border-primary/30 transition-all flex items-center gap-4 group">
            <div class="size-10 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                <span class="material-symbols-outlined">chat</span>
            </div>
            <div>
                <p class="font-bold text-slate-900">Messages</p>
                <p class="text-xs text-slate-500">@Model.UnreadMessages unread</p>
            </div>
        </a>
        <a asp-action="Notifications" class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm hover:shadow-md hover:border-primary/30 transition-all flex items-center gap-4 group">
            <div class="size-10 rounded-lg bg-amber-50 flex items-center justify-center text-amber-600 group-hover:bg-amber-600 group-hover:text-white transition-colors">
                <span class="material-symbols-outlined">notifications</span>
            </div>
            <div>
                <p class="font-bold text-slate-900">Notifications</p>
                <p class="text-xs text-slate-500">@Model.UnreadNotifications unread</p>
            </div>
        </a>
    </div>

    <!-- Recent Bookings -->
    <div>
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-slate-900">Recent Bookings</h3>
            <a asp-action="Bookings" class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                View All <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>

        @if (Model.RecentBookings.Any())
        {
            <div class="space-y-3">
                @foreach (var booking in Model.RecentBookings)
                {
                    var statusClass = booking.Status switch
                    {
                        "Confirmed" => "bg-emerald-100 text-emerald-700",
                        "Pending" => "bg-amber-100 text-amber-700",
                        "Cancelled" => "bg-red-100 text-red-700",
                        "Rejected" => "bg-red-100 text-red-700",
                        _ => "bg-slate-100 text-slate-700"
                    };

                    <a asp-action="BookingDetails" asp-route-id="@booking.BookingId"
                       class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 flex items-center gap-4 hover:shadow-md hover:border-primary/20 transition-all">
                        <img src="@booking.CoverImageUrl" class="w-16 h-16 rounded-lg object-cover flex-shrink-0" onerror="this.src='/images/default-venue.jpg'" alt="@booking.VenueName" />
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2">
                                <h4 class="font-bold text-slate-900 truncate">@booking.VenueName</h4>
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold shrink-0 @statusClass">@booking.Status</span>
                            </div>
                            <p class="text-sm text-slate-500 mt-0.5">@booking.EventType · @booking.StartDate.ToString("MMM dd, yyyy") · @booking.ThemeName</p>
                        </div>
                        <div class="text-right shrink-0">
                            <p class="text-lg font-bold text-primary">₹@booking.TotalPrice.ToString("N0")</p>
                            <p class="text-[10px] text-slate-400 uppercase font-bold">@booking.PaymentStatus</p>
                        </div>
                        <span class="material-symbols-outlined text-slate-300">chevron_right</span>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-10 text-center">
                <span class="material-symbols-outlined text-5xl text-slate-300 mb-3">event_busy</span>
                <h3 class="text-xl font-bold text-slate-700">No Bookings Yet</h3>
                <p class="text-slate-500 mt-2">Explore venues and book your first event!</p>
                <a asp-controller="Home" asp-action="Index" class="inline-block mt-4 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 transition-colors">
                    Browse Venues
                </a>
            </div>
        }
    </div>
</div>