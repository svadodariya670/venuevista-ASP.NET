@model VenueBooking.ViewModels.CustomerSettingsViewModel
@{
    ViewData["Title"] = "Settings";
    Layout = "_CustomerLayout";
}

<div class="max-w-3xl mx-auto space-y-8">
    <div>
        <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Account Settings</h2>
        <p class="text-slate-500 mt-1">Manage your profile and security preferences.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="p-4 bg-emerald-50 border border-emerald-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <p class="text-sm font-medium text-emerald-800">@TempData["Success"]</p>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600">error</span>
            <p class="text-sm font-medium text-red-800">@TempData["Error"]</p>
        </div>
    }

    <!-- Profile Section -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">person</span>
            <h3 class="text-lg font-bold text-slate-900">Profile Information</h3>
        </div>
        <form asp-action="UpdateProfile" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <div class="space-y-4">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-slate-700 mb-1">Full Name *</label>
                    <input asp-for="Name" class="w-full px-4 py-2.5 bg-slate-100 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="Your full name" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1"></span>
                </div>
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-slate-700 mb-1">Email Address *</label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-2.5 bg-slate-100 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                </div>
                <div>
                    <label asp-for="Phone" class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
                    <input asp-for="Phone" type="tel" class="w-full px-4 py-2.5 bg-slate-100 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="+91 9876543210" />
                    <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>
            <div class="mt-6 flex justify-end">
                <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-bold hover:bg-primary/90 shadow-lg shadow-primary/30 flex items-center gap-2">
                    <span class="material-symbols-outlined text-lg">save</span>
                    Save Changes
                </button>
            </div>
        </form>
    </div>

    <!-- Change Password Section -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">lock</span>
            <h3 class="text-lg font-bold text-slate-900">Change Password</h3>
        </div>
        <form asp-action="ChangePassword" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Current Password *</label>
                    <input type="password" name="currentPassword" class="w-full px-4 py-2.5 bg-slate-100 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="Enter current password" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">New Password *</label>
                    <input type="password" name="newPassword" class="w-full px-4 py-2.5 bg-slate-100 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="At least 6 characters" minlength="6" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Confirm New Password *</label>
                    <input type="password" name="confirmPassword" class="w-full px-4 py-2.5 bg-slate-100 border-none rounded-xl text-sm focus:ring-2 focus:ring-primary/20" placeholder="Re-enter new password" minlength="6" required />
                </div>
            </div>
            <div class="mt-6 flex justify-end">
                <button type="submit" class="px-6 py-2.5 bg-slate-800 text-white rounded-xl text-sm font-bold hover:bg-slate-700 flex items-center gap-2">
                    <span class="material-symbols-outlined text-lg">lock_reset</span>
                    Update Password
                </button>
            </div>
        </form>
    </div>

    <!-- Danger Zone -->
    <div class="bg-white rounded-2xl border border-red-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-red-100 flex items-center gap-3">
            <span class="material-symbols-outlined text-red-500">warning</span>
            <h3 class="text-lg font-bold text-red-700">Danger Zone</h3>
        </div>
        <div class="p-6">
            <p class="text-sm text-slate-600 mb-4">Once you delete your account, there is no going back. All your bookings and data will be permanently removed.</p>
            <button type="button" onclick="confirmDelete()" class="px-5 py-2.5 bg-red-50 text-red-600 border border-red-200 rounded-xl text-sm font-bold hover:bg-red-100 transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">delete_forever</span>
                Delete Account
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete() {
            if (confirm('Are you sure you want to delete your account? This action is permanent and cannot be undone.')) {
                alert('Account deletion is not yet implemented. Contact support.');
            }
        }
    </script>
}